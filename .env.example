# Copy this file to .env and fill in your values
# NEVER commit .env to git

# MongoDB Atlas connection string
# Get this from: Atlas Dashboard → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/brust_cafe?retryWrites=true&w=majority

# URL of your deployed React frontend (for CORS)
FRONTEND_URL=http://localhost:3000

# Server port (Render sets this automatically)
PORT=5000
